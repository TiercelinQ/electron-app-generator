{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Read(**/.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/node_modules/**)",
      "Write(**/out/**)",
      "Write(**/release/**)",
      "Write(**/dist/**)"
    ]
  }
}
