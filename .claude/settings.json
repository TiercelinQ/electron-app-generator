{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read",
      "Write",
      "Edit",
      "Bash(echo \"ensure-electron OK \\(exit $?\\)\")",
      "PowerShell($env:ELECTRON_RUN_AS_NODE=$null; npm run typecheck; if \\($?\\) { npm run lint })"
    ],
    "deny": [
      "Read(**/.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/node_modules/**)",
      "Write(**/out/**)",
      "Write(**/release/**)",
      "Write(**/dist/**)"
    ]
  }
}
